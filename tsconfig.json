{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "vitepress": ["./node_modules/vitepress/dist/client"]
    }
  },
  "include": [
    "docs/.vitepress/**/*",
    "docs/**/*.vue",
    "docs/**/*.ts"
  ]
}
